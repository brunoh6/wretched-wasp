---
const { title, description, image, reverse = false } = Astro.props;
---

<section class="py-20">
  <div
    class={`mx-auto max-w-7xl px-6 grid gap-12 items-center ${
      reverse ? "md:grid-cols-[1fr_1.2fr]" : "md:grid-cols-[1.2fr_1fr]"
    }`}
  >
    {!reverse && (
      <img
        src={image}
        alt={title}
        class="w-full h-80 object-cover rounded"
        loading="lazy"
      />
    )}

    <div>
      <h2 class="text-3xl font-bold mb-4">{title}</h2>
      <p class="text-gray-700 max-w-xl">{description}</p>
    </div>

    {reverse && (
      <img
        src={image}
        alt={title}
        class="w-full h-80 object-cover rounded"
        loading="lazy"
      />
    )}
  </div>
</section>