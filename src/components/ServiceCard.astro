---
const { title, description, image } = Astro.props;
---

<div class="group relative overflow-hidden rounded-lg shadow-lg">
  <img
    src={image}
    alt={title}
    class="h-72 w-full object-cover transition-transform duration-500 group-hover:scale-105"
    loading="lazy"
  />

  <div class="absolute inset-0 bg-black/60 flex flex-col justify-end p-6">
    <h3 class="text-white text-xl font-semibold mb-2">
      {title}
    </h3>

    <p class="text-gray-200 text-sm leading-relaxed">
      {description}
    </p>
  </div>
</div>