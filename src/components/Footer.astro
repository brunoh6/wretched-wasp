<footer class="bg-gray-900 text-gray-300 mt-24">
  <div class="mx-auto max-w-7xl px-6 py-16 grid gap-12 md:grid-cols-3">

    <!-- Empresa -->
    <div>
      <h3 class="text-white font-bold text-lg">DIHYC</h3>
      <p class="text-sm mt-4 leading-relaxed">
        Distribuciones e Importaciones H&C, soluciones industriales en
        tubosistemas, conexiones y servicios especializados para proyectos
        comerciales e industriales en Perú.
      </p>
    </div>

    <!-- Contacto -->
    <div>
      <h4 class="text-white font-semibold mb-4">Contacto</h4>
      <ul class="text-sm space-y-2">
        <li>Teléfono: (01) XXX-XXXX</li>
        <li>WhatsApp: +51 XXX XXX XXX</li>
        <li>Email: contacto@dihyc.com</li>
        <li>Lima, Perú</li>
      </ul>
    </div>

    <!-- Navegación -->
    <div>
      <h4 class="text-white font-semibold mb-4">Enlaces</h4>
      <ul class="text-sm space-y-2">
        <li><a href="/" class="hover:text-white transition">Inicio</a></li>
        <li><a href="/empresa" class="hover:text-white transition">Empresa</a></li>
        <li><a href="/productos" class="hover:text-white transition">Productos</a></li>
        <li><a href="/servicios" class="hover:text-white transition">Servicios</a></li>
        <li><a href="/contacto" class="hover:text-white transition">Contáctanos</a></li>
      </ul>
    </div>

  </div>

  <div class="border-t border-gray-700 text-center text-xs text-gray-500 py-6">
    © {new Date().getFullYear()} DIHYC. Todos los derechos reservados.
  </div>
</footer>