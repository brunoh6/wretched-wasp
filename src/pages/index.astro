<BaseLayout
  title="H & C"
  description="Distribución de productos industriales y servicios especializados."
>

  <!-- 1️⃣ HERO -->
  <Hero
    title="Distribuciones e Importaciones, H & C"
    subtitle="Diversos productos en tubosistemas y conexiones."
    ctaLabel="Contáctanos"
    ctaHref="/contacto"
    image="/assets/hero/home.png"
  />

  <!-- 2️⃣ SERVICIOS DESTACADOS -->
  <Section title="Servicios Especializados en Soldadura Industrial">
    <div class="grid md:grid-cols-2 gap-10">
      <ServiceCard
        title="Soldadura por Termofusión"
        description="Unión de tuberías plásticas con máxima resistencia y seguridad."
        image="/assets/services/termofusion.png"
      />

      <ServiceCard
        title="Soldadura por Electrofusión"
        description="Instalaciones industriales con alta precisión y confiabilidad."
        image="/assets/services/electrofusion.png"
      />
    </div>
  </Section>

  <!-- 3️⃣ MARCAS -->
  <Section class="bg-gray-100 py-20" title="Distribuimos las mejores marcas">
    <BrandCarousel
      brands={[
      { name: "+GF+", logo: "/assets/brands/gf.png" },
      { name: "Hakan Plastik", logo: "/assets/brands/hakan.png" },
      { name: "Leister", logo: "/assets/brands/leister.png" },
	  { name: "Simona", logo: "/assets/brands/simona.png" },
	  { name: "Victaulic", logo: "/assets/brands/victaulic.png" },
	  { name: "Integrity", logo: "/assets/brands/integrity.png" },
	  { name: "Arrow", logo: "/assets/brands/arrow.png" },
	  { name: "Cepex", logo: "/assets/brands/cepex.png" },
	  { name: "Cim", logo: "/assets/brands/cim.png" },
	  { name: "Era", logo: "/assets/brands/era.png" }
    ]}
    />
  </Section>

  <!-- 4️⃣ EMPRESA -->
<Section title="Nuestra Empresa">
  <div class="grid md:grid-cols-2 gap-16 items-center">

    <div class="relative">
      <img
        src="/assets/hero/empresa.png"
        alt="Nuestra empresa"
        class="rounded-lg object-cover w-full h-[420px] shadow-lg"
      />
    </div>

    <div class="space-y-6">
      <p class="text-gray-700 leading-relaxed">
        H&C es una empresa especializada en la distribución de soluciones industriales...
      </p>

      <p class="text-gray-700 leading-relaxed">
        Trabajamos con marcas certificadas y ofrecemos asesoría técnica personalizada...
      </p>

      <a
        href="/empresa"
        class="inline-block mt-4 border px-6 py-3 text-sm font-medium hover:bg-gray-900 hover:text-white transition"
      >
        Conócenos
      </a>
    </div>
  </div>
</Section>

  <!-- 5️⃣ MISIÓN Y VISIÓN (NUEVO EN HOME) -->
<Section title="Misión y Visión">
  <div class="grid md:grid-cols-2 gap-10">

    <div class="p-8 bg-gray-100 rounded-lg shadow-sm hover:shadow-md transition">
      <h3 class="text-xl font-semibold mb-4">Misión</h3>
      <p class="text-gray-700 leading-relaxed">
        Proveer productos industriales de alta calidad...
      </p>
    </div>

    <div class="p-8 bg-gray-100 rounded-lg shadow-sm hover:shadow-md transition">
      <h3 class="text-xl font-semibold mb-4">Visión</h3>
      <p class="text-gray-700 leading-relaxed">
        Consolidarnos como referente en soluciones industriales...
      </p>
    </div>

  </div>
</Section>

  <!-- 6️⃣ FORMULARIO -->
<section class="bg-gray-100 py-20">
  <div class="mx-auto max-w-4xl px-6 bg-white p-12 rounded-lg shadow-lg">
    <h2 class="text-3xl font-semibold mb-8 text-center">
      Solicita información
    </h2>

    <ContactForm />
  </div>
</section>

</BaseLayout>