<BaseLayout
  title="Productos | DIHYC"
  description="Catálogo de soluciones industriales organizado por categorías."
>

  <Hero
    title="Nuestros Productos"
    subtitle="Explora nuestras soluciones industriales organizadas por categorías."
  />

  <Section>
    <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-8">

      {categories.map((category) => (
        <a
          href={`/productos/${category.slug}`}
          class="group block border rounded-lg overflow-hidden hover:shadow-lg transition"
        >
          <div class="aspect-[4/3] overflow-hidden bg-gray-100">
            <img
              src={category.image}
              alt={category.name}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
            />
          </div>

          <div class="p-6">
            <h3 class="text-lg font-semibold">
              {category.name}
            </h3>

            <p class="text-sm text-gray-600 mt-2">
              Ver productos
            </p>
          </div>
        </a>
      ))}

    </div>
  </Section>

</BaseLayout>